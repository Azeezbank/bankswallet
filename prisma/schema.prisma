generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AirtimeN {
  d_id      Int                 @id @default(autoincrement())
  name      String?
  is_active AirtimeN_is_active? @default(active)
  id        Int?
}

model AirtimeT {
  d_id      Int                 @id @default(autoincrement())
  name      String?
  is_active AirtimeT_is_active? @default(active)
}

model admin_setting {
  d_id            Int     @id @default(autoincrement())
  whatsapp_phone  String?
  whatsapp_link   String?
  dash_message    String? @db.Text
  whatsapp_number String?
}

model airtimeHist {
  d_id             Int       @id @default(autoincrement())
  id               Int?
  txRef            String?      @unique
  network          String?
  amount           Decimal   @default(0.00) @db.Decimal(10, 2)
  phone_number     String?
  previous_balance Decimal   @default(0.00) @db.Decimal(10, 2)
  new_balance      Decimal   @default(0.00) @db.Decimal(10, 2)
  time             DateTime?
  status           String?
  airtimeType      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now())
}

model cable {
  d_id      Int              @id @default(autoincrement())
  id        Int
  provider  String
  is_active cable_is_active? @default(active)
}

model cableHist {
  d_id         Int      @id @default(autoincrement())
  id           Int
  txRef        String?      @unique
  providername String
  cable_name   String
  amount       Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  customerName String
}

model cablePlan {
  d_id           Int                  @id @default(autoincrement())
  id             Int
  provider       String
  cable_name     String
  user_price     Decimal              @default(0.00) @db.Decimal(10, 2)
  reseller_price Decimal              @default(0.00) @db.Decimal(10, 2)
  api_price      Decimal              @default(0.00) @db.Decimal(10, 2)
  is_active      cablePlan_is_active? @default(active)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @default(now())
}

model cablenumber {
  d_id      Int                    @id @default(autoincrement())
  number    String
  is_active cablenumber_is_active? @default(active)
}

model dataTransactionHist {
  d_id           Int                           @id @default(autoincrement())
  id             Int?
  txRef          String?                      @unique
  network        String?
  plan           String?
  phone_number   String?
  amount         Decimal                       @default(0.00) @db.Decimal(10, 2)
  balance_before Decimal                       @default(0.00) @db.Decimal(10, 2)
  balance_after  Decimal                       @default(0.00) @db.Decimal(10, 2)
  status         String?
  time           DateTime                      @default(now())
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @default(now())
  condition      dataTransactionHist_condition @default(Pending)
}

model data_plans {
  d_id         Int                   @id @default(autoincrement())
  id           Int?
  name         String?
  network_name String?
  data_type    String?
  validity     String?
  is_active    data_plans_is_active? @default(active)
  USER         Decimal               @default(0.00) @db.Decimal(10, 2)
  RESELLER     Decimal               @default(0.00) @db.Decimal(10, 2)
  API          Decimal               @default(0.00) @db.Decimal(10, 2)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @default(now())
}

model data_types {
  d_id         Int                   @id @default(autoincrement())
  name         String?
  is_active    data_types_is_active? @default(active)
  network_name String?
}

model env {
  d_id         Int     @id @default(autoincrement())
  service_type String  @unique
  api_key      String? @db.Text
  api_url      String? @db.Text
}

model networks {
  d_id      Int                 @id @default(autoincrement())
  name      String?             @db.VarChar(10)
  is_active networks_is_active? @default(active)
  id        Int?
}

model paymentHist {
  d_id           Int      @id @default(autoincrement())
  id             Int?
  event_type     String?  @db.VarChar(100)
  payment_ref    String?  @db.VarChar(255)
  paid_on        String?
  amount         Decimal  @default(0.00) @db.Decimal(10, 2)
  payment_method String?  @db.VarChar(255)
  payment_status String?  @db.VarChar(50)
  prev_balance   Decimal  @default(0.00) @db.Decimal(10, 2)
  user_balance   Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now())
}

model transactionWebHook {
  d_id             Int       @id @default(autoincrement())
  webHook_response String?   @db.VarChar(800)
  create_date      DateTime?
}

model userBankDetails1 {
  d_id      Int                         @id @default(autoincrement())
  id        Int
  acctNo    String?                     @db.VarChar(255)
  acctName  String?                     @db.VarChar(255)
  bankName  String?                     @db.VarChar(255)
  is_active userBankDetails1_is_active? @default(active)
  acct_id   String
}

model users {
  d_id            Int             @id @default(autoincrement())
  username        String          @unique @db.VarChar(20)
  user_pass       String          @db.VarChar(255)
  user_email      String          @unique @db.VarChar(100)
  user_registered DateTime?       @default(now()) @db.Timestamp(0)
  prev_balance    Decimal         @default(0.00) @db.Decimal(10, 2)
  user_balance    Decimal         @default(0.00) @db.Decimal(10, 2)
  packages        users_packages? @default(USER)
  Pin             Int             @default(0)
  Phone_number    String?         @db.VarChar(15)
  role            users_role?     @default(user)
  nin             String?         @db.VarChar(11)
  verificationOTP String?         @unique @db.VarChar(100)
  isverified      Boolean         @default(false)
  fullName        String?         @db.VarChar(255)
  isban           Boolean         @default(false)
  cashback        Decimal         @default(0.00) @db.Decimal(10, 2)
  isFund          Boolean         @default(false)
  referral        String?
  referree        Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now())
}

enum AirtimeN_is_active {
  active
  disabled
}

enum AirtimeT_is_active {
  active
  disabled
}

enum cablenumber_is_active {
  active
  disabled
}

enum data_types_is_active {
  active
  disabled
}

enum networks_is_active {
  active
  disabled
}

enum cable_is_active {
  active
  disabled
}

enum userBankDetails1_is_active {
  active
  disabled
}

enum data_plans_is_active {
  active
  disabled
}

enum cablePlan_is_active {
  active
  disabled
}

enum users_packages {
  USER
  RESELLER
  API
}

enum users_role {
  admin
  user
}

enum dataTransactionHist_condition {
  Pending
  Successful
  Failed
}
